# ============================================
# Miami Residences - Variables de entorno
# ============================================
# Copiá este archivo a .env.local y completá los valores
# El archivo .env.local NO se sube a Git (está en .gitignore)

# Entorno de ejecución
NODE_ENV=production

# ============================================
# Bridge Interactive API (MLS data)
# ============================================
# Registrate en: https://bridgedataoutput.com/register
# Solicitá acceso al dataset de Miami REALTORS
# Mientras no tengas el API key, la app usa datos mock automáticamente
BRIDGE_API_KEY=
BRIDGE_DATASET_ID=miamire

# ============================================
# (Opcional) Google Analytics & Search Console
# ============================================
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_GTM_CONTAINER_ID=
